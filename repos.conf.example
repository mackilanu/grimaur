# grimoire repo aliases -- example.
# Auto-generated on first run.
# then use any of: install / fetch / inspect / search / update <pkg> 
# [--repo <NAME>] forces a single source. Other-wise first is primary.
#
# Manage with `grimoire repo --add/--rm/--ls`.
# In a URL, {pkg} is replaced by the package name and {pkgbase} by its pkgbase
# (looked up from the local pacman sync DBs, so split packages resolve too).

# Default: Arch's official packages, one repo per pkgbase on the GitLab
# bare `grimoire install <pkg>` builds the official package from source.
[ARCH]
  https://gitlab.archlinux.org/archlinux/packaging/packages/{pkgbase}.git

# A custom subdir-container repo: one dir per package under pkgs/.
[VUR]
  https://codeberg.org/myuser/myaur/tree/master/pkgs

# The AUR (RPC API + git mirror). Uncomment if desired.
#[AUR]
#  https://aur.archlinux.org/rpc/
#  https://github.com/archlinux/aur.git
